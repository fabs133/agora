__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.venv/
venv/
dist/
build/

# Conduit homeserver: ship the example, ignore the live config + state.
conduit/conduit.toml
conduit/data/

# Workspace runtime caches. Run archives themselves (workspace/<run>/...)
# are tracked deliberately — they're the empirical evidence cited from
# the README and lessons-learned. Future runs that produce new dirs are
# the user's responsibility to stage or skip.
workspace/.knowledge/
workspace/.logs/*.tmp
# Active scratch working-dirs with their OWN nested .git (separate repos, not
# run archives) — skipped per the policy above so they stop showing as strays.
workspace/discord-bot/
workspace/tool-call-fidelity/

# Structured run-logging output (run.jsonl / tasks.jsonl per run). These are
# empirical run artefacts the user stages deliberately, not tracked source.
runs_out/

# Sphinx build artefacts and autosummary stubs.
docs/_build/
docs/api/_autosummary/

# Working file used during run-archive build; safe to regenerate.
docs/runs/_inventory.csv

# Local env / editor noise.
.env
.idea/
.vscode/

# Claude Code state — entirely local. The allowlists here name MCP servers and
# tools that exist on one author's machine, so they are meaningless (and
# misleading) to anyone cloning: nothing in Agora requires them.
.claude/

# Personal working notes — not part of the project record.
INBOX.md
