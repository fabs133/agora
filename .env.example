# =============================================================================
#  Agora — example environment.  ***LOCAL DEV ONLY.***
#
#  Copy this file to .env  (cp .env.example .env)  and edit as needed.
#  .env is gitignored and must NEVER be committed. These values are throwaway
#  dev credentials for a local, disposable stack — do not reuse them anywhere
#  real. Every key is an AGORA_* setting read by src/agora/config.py (the one
#  place environment is read).
# =============================================================================

# --- Matrix (Conduit homeserver) --------------------------------------------
AGORA_MATRIX_HOMESERVER=http://localhost:6167
AGORA_MATRIX_SERVER_NAME=agora.local
AGORA_MATRIX_USER_ID=@agora:agora.local

# REQUIRED. The system agent's Matrix password. There is no default — a run
# fails loudly (naming this variable) if it is unset. Set it to the password you
# use when registering the @agora account on your local Conduit.
AGORA_MATRIX_PASSWORD=agora-dev-pass

# The Conduit registration token. Must EXACTLY match `registration_token` in
# conduit/conduit.toml (see conduit/conduit.example.toml for the template).
AGORA_MATRIX_REGISTRATION_TOKEN=dev_only_CHANGE_ME

# Human observer identity — a neutral default; change to your own Matrix id if
# you want to watch/vote from your account in Element.
AGORA_OBSERVER_USER=@observer:agora.local
AGORA_OBSERVER_PASSWORD=observer-dev-pass

# --- LLM (Ollama is the only backend) ---------------------------------------
AGORA_OLLAMA_BASE_URL=http://localhost:11434
AGORA_LLM_MODEL=ollama/qwen2.5:7b-instruct
# Named profile from profiles.yaml ("" = the file's default). Optional.
# AGORA_PROFILE=
# Explicit profiles.yaml path ("" = ./profiles.yaml, then the packaged default).
# AGORA_PROFILES_FILE=

# --- Optional behavioural knobs (defaults shown; uncomment to override) ------
# AGORA_MAX_PARALLEL_AGENTS=3
# AGORA_MAX_TASK_RETRIES=2
# AGORA_REVIEW_TIMEOUT_SECONDS=86400
# AGORA_SKIP_VRAM_CHECK=0
# AGORA_SKIP_LLM_WARMUP=0

# --- Harness reliability knobs (campaign-emitted; defaults shown) ------------
# AGORA_HARNESS_TOOL_ERRORS=raw          # raw | corrective
# AGORA_HARNESS_NUDGE_BUDGET=0
# AGORA_HARNESS_REVIEW_BUDGET=0
# AGORA_HARNESS_SALVAGE_BUDGET=0
